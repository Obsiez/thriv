# API (production — Railway/Render)
PORT=3001
NODE_ENV=production
JWT_SECRET=generate-a-long-random-secret-minimum-32-characters
CORS_ORIGIN=https://your-app.vercel.app

# Frontend (Vercel) — full API URL, no trailing slash
VITE_API_URL=https://your-api.up.railway.app

# Firebase Configuration (Optional - replaces custom Express API server with Serverless Cloud)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
